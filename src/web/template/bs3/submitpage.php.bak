          <?php endif; ?>

          <!-- 메타 정보 -->
          <div class="submit-meta">
            <div class="submit-meta-item">
              📋 문제:
              <?php if(isset($id)): ?>
                <strong><a href="problem.php?id=<?php echo $id?>" style="color:#1a6fc4">No. <?php echo $id?></a></strong>
