    <form id="frmSolution" action="submit.php" method="post" onsubmit="do_submit()">

      <!-- 제출 카드 -->
      <div class="submit-card">
        <div class="submit-card-header">
          ✏️ 코드 제출
        </div>
        <div class="submit-card-body">

          <!-- 숨김 필드 -->
          <?php if(isset($id)): ?>
